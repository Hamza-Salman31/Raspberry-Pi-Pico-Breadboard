# ── PIN SETUP ──────────────────────────────────────────
temp_sensor = machine.ADC(27)       # NTC thermistor on GP27
blue_led = machine.Pin(18, machine.Pin.OUT)   # Lighting actuator
red_led  = machine.Pin(17, machine.Pin.OUT)   # HVAC actuator

# ── SENSOR FUNCTIONS ───────────────────────────────────
def get_tempSensorValue():
    tempSensorValue = temp_sensor.read_u16()
    tempValue = round(((((1/(1/298+(1/3960)*math.log((65535/(tempSensorValue)-1)))) - 273)*1)),1)
    return str(tempValue)

