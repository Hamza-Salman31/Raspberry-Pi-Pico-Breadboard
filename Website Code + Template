# ── SOCKET SERVER ──────────────────────────────────────
s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
s.bind(('', 80))
s.listen(5)

# track LED states
led_status  = "OFF"
hvac_status = "OFF"

# ── MAIN LOOP ──────────────────────────────────────────
while True:
    conn, addr = s.accept()
    print('Connection from:', str(addr))
    request = conn.recv(1024)
    request = str(request)
    print(request)

    # check button presses from webpage
    if '/?led=on'   in request:
        blue_led.value(1)
        led_status = "ON"
    if '/?led=off'  in request:
        blue_led.value(0)
        led_status = "OFF"
    if '/?hvac=on'  in request:
        red_led.value(1)
        hvac_status = "ON"
    if '/?hvac=off' in request:
        red_led.value(0)
        hvac_status = "OFF"

    # get sensor values
    tempValue   = get_tempSensorValue()
    lightValue  = get_lightSensorValue()
    motionStatus = get_motionStatus()

    # build and send response
    response = web_page(tempValue, lightValue, motionStatus, led_status, hvac_status)
    conn.send("HTTP/1.1 200 OK\n")
    conn.send("Content-Type: text/html\n")
    conn.send("Connection: close\n\n")
    conn.sendall(response)
    conn.close()
