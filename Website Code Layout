def web_page(tempValue, lightValue, motionStatus, ledStatus, hvacStatus):
    html = f"""<!DOCTYPE html>
<html>
<head>
  <title>Smart Room Control</title>
  <meta http-equiv="refresh" content="5">
</head>
<body>

  <h1>Smart Room Energy Management</h1>
  <p>Group 3 - B02 | Raspberry Pi Pico W</p>
  <hr>

  <h2>Sensor Readings</h2>
  <p>Temperature: {tempValue} degrees Celsius</p>
  <p>Light Level: {lightValue} lux</p>
  <p>Motion Status: {motionStatus}</p>

  <h2>Actuator Status</h2>
  <p>Lighting LED (Blue): {ledStatus}</p>
  <p>HVAC LED (Red): {hvacStatus}</p>

  <h2>Manual Controls</h2>
  <a href="/?led=on"><button>Light ON</button></a>
  <a href="/?led=off"><button>Light OFF</button></a>
  <br><br>
  <a href="/?hvac=on"><button>HVAC ON</button></a>
  <a href="/?hvac=off"><button>HVAC OFF</button></a>

  <h2>System Mode</h2>
  <a href="/?mode=auto"><button>Automatic</button></a>
  <a href="/?mode=manual"><button>Manual</button></a>
  <a href="/?mode=vacation"><button>Vacation</button></a>

</body>
</html>"""
    return str(html)
